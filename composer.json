{
  "name": "betterauth/laravel",
  "description": "Modern authentication for Laravel with Paseto V4 tokens, OAuth, 2FA, and Magic Links",
  "keywords": [
    "laravel",
    "authentication",
    "paseto",
    "oauth",
    "2fa",
    "magic-link"
  ],
  "license": "MIT",
  "type": "library",
  "authors": [
    {
      "name": "BetterAuth Team",
      "email": "hello@betterauth.dev"
    }
  ],
  "require": {
    "php": "^8.2",
    "illuminate/auth": "^10.0|^11.0|^12.0",
    "illuminate/contracts": "^10.0|^11.0|^12.0",
    "illuminate/database": "^10.0|^11.0|^12.0",
    "illuminate/http": "^10.0|^11.0|^12.0",
    "illuminate/routing": "^10.0|^11.0|^12.0",
    "illuminate/support": "^10.0|^11.0|^12.0",
    "paragonie/paseto": "^3.1",
    "ramsey/uuid": "^4.7"
  },
  "suggest": {
    "api-platform/laravel": "Expose BetterAuth endpoints inside API Platform OpenAPI docs",
    "laravel/socialite": "Required for OAuth authentication (Google, GitHub, Facebook, etc.)"
  },
  "require-dev": {
    "larastan/larastan": "^3.0",
    "laravel/pint": "^1.0",
    "laravel/socialite": "^5.24",
    "orchestra/testbench": "^8.0|^9.0|^10.0",
    "pestphp/pest": "^2.0|^3.0",
    "phpstan/phpstan": "^2.1"
  },
  "autoload": {
    "psr-4": {
      "BetterAuth\\Laravel\\": "src/",
      "BetterAuth\\Core\\": "core-embedded/core/",
      "BetterAuth\\Providers\\": "core-embedded/providers/",
      "BetterAuth\\Contracts\\": "core-embedded/contracts/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "BetterAuth\\Laravel\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "pest",
    "test:coverage": "pest --coverage",
    "phpstan": "phpstan analyse --memory-limit=512M",
    "pint": "pint",
    "pint:test": "pint --test",
    "ci": [
      "@pint:test",
      "@phpstan",
      "@test"
    ]
  },
  "extra": {
    "laravel": {
      "providers": [
        "BetterAuth\\Laravel\\BetterAuthServiceProvider"
      ],
      "aliases": {
        "BetterAuth": "BetterAuth\\Laravel\\Facades\\BetterAuth"
      }
    },
    "branch-alias": {
      "dev-main": "0.0.x-dev"
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
